# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

project_id   = "your-gcp-project-id"
region       = "us-central1"
cluster_name = "hemisphere-cluster"

# Vertex AI (optional -- leave empty to skip model deployment)
vertex_display_name  = "hemisphere-endpoint"
vertex_model_id      = ""
vertex_traffic_split = {}

# Employee namespace resource quotas (minimal for testing)
employee_cpu_quota    = "2"
employee_memory_quota = "2Gi"
employee_pod_quota    = "10"

# GitHub integration (optional -- auto-rebuild images on push to main)
# Leave github_owner empty to skip. The deploy script will prompt you.
# If you set this, you must also connect your repo in the GCP Console:
#   https://console.cloud.google.com/cloud-build/triggers/connect
# github_owner = "your-github-username"
# github_repo  = "Agentic-Hemisphere-Kubernetes"
